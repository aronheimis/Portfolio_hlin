# Sanity — create a project at https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token for server-side data fetching (read-only is fine)
SANITY_API_READ_TOKEN=your_read_token_here

# Resend — create an account at https://resend.com
# Free tier allows 3,000 emails/month
RESEND_API_KEY=re_your_api_key_here

# Used for on-demand revalidation (generate any random 32-char string)
SANITY_REVALIDATE_SECRET=your_random_secret_here
